# DSMR MQTT Bridge Configuration
# Copy this file to /etc/dsmr-mqtt.conf and set the real credentials.
# Keep it root-readable only:
#
#   sudo chown root:root /etc/dsmr-mqtt.conf
#   sudo chmod 600 /etc/dsmr-mqtt.conf

DSMR_SERIAL_DEVICE=/dev/serial/by-id/usb-FTDI_P1_CABLE-if00-port0
DSMR_MQTT_BROKER=tcp://mqtt-broker.local:1883
DSMR_MQTT_CLIENT_ID=dsmr-bridge
DSMR_MQTT_USERNAME=your_mqtt_username
DSMR_MQTT_PASSWORD=your_mqtt_password

# Optional:
# DSMR_MQTT_TLS=1
# DSMR_VERBOSE=1

# Security note: for non-local deployments, use TLS to encrypt connections:
# - Use ssl:// or tls:// URL scheme, or
# - Set DSMR_MQTT_TLS=1 with tcp:// URL
